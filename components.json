<script>
/* LOADER — typewriter style */
(function(){
  const loader=document.getElementById('loader');
  const bar=document.getElementById('loaderBar');
  function typeInto(elId,text,delay,cb){
    const el=document.getElementById(elId);
    let i=0;
    const iv=setInterval(()=>{
      el.textContent+=text[i++];
      if(i>=text.length){clearInterval(iv);if(cb)cb();}
    },delay);
  }
  // Line 1
  setTimeout(()=>{
    document.getElementById('lc1').style.display='';
    typeInto('lt1','load portfolio --user=arjun-mehta',28,()=>{
      document.getElementById('lc1').style.display='none';
      setTimeout(()=>{
        document.getElementById('ll2').style.opacity='1';
        document.getElementById('lc2').style.display='';
        typeInto('lt2','Bundling assets... done.',18,()=>{
          document.getElementById('lc2').style.display='none';
          setTimeout(()=>{
            document.getElementById('ll3').style.opacity='1';
            typeInto('lt3','Portfolio ready. Launching...',22);
          },200);
        });
      },300);
    });
  },200);
  // Progress
  let p=0;const iv=setInterval(()=>{p+=Math.random()*3+1;if(p>=100){p=100;clearInterval(iv);}bar.style.width=p+'%';},30);
  setTimeout(()=>{loader.classList.add('done');startHero();},2000);
})();

/* HERO TYPEWRITER */
function startHero(){
  const lines=[
    'I build software',
    'that actually',
    'ships.'
  ];
  const el=document.getElementById('typedLine');
  const cur=document.getElementById('heroCursor');
  let lineIdx=0,charIdx=0;
  function type(){
    if(lineIdx>=lines.length){
      setTimeout(()=>{
        document.getElementById('heroSub').classList.add('go');
        document.getElementById('heroBtns').classList.add('go');
        cur.style.display='none';
      },400);
      return;
    }
    const line=lines[lineIdx];
    if(charIdx<line.length){
      el.innerHTML=lines.slice(0,lineIdx).map(l=>`<div>${l}</div>`).join('')+`<div>${line.slice(0,charIdx+1)}</div>`;
      charIdx++;setTimeout(type,55);
    } else {
      el.innerHTML=lines.slice(0,lineIdx+1).map(l=>`<div>${l}</div>`).join('');
      lineIdx++;charIdx=0;setTimeout(type,lineIdx<lines.length?200:0);
    }
  }
  setTimeout(type,200);
}

window.addEventListener('scroll',()=>{
  const p=window.scrollY/(document.body.scrollHeight-window.innerHeight);
  document.getElementById('progress').style.width=(p*100)+'%';
  document.getElementById('nav').classList.toggle('scrolled',window.scrollY>50);
},{passive:true});

const ro=new IntersectionObserver(e=>{e.forEach(en=>{if(en.isIntersecting)en.target.classList.add('vis')});},{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

const co=new IntersectionObserver(e=>{
  e.forEach(en=>{
    if(!en.isIntersecting||en.target._done)return;en.target._done=true;
    const t=+en.target.dataset.target,sf=en.target.dataset.suffix||'+';
    let v=0;const inc=t/55;
    const iv=setInterval(()=>{v+=inc;if(v>=t){v=t;clearInterval(iv);}en.target.textContent=Math.floor(v)+sf;},1200/55);
  });
},{threshold:.5});
document.querySelectorAll('.stat-n[data-target]').forEach(el=>co.observe(el));

document.querySelectorAll('.faq-q').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const item=btn.parentElement,ans=item.querySelector('.faq-a'),open=item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i=>{i.classList.remove('open');i.querySelector('.faq-a').style.maxHeight='0';});
    if(!open){item.classList.add('open');ans.style.maxHeight=ans.scrollHeight+'px';}
  });
});
</script>
